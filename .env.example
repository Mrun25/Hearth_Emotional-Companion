# Fumii Fine-Tuning Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Hugging Face access token (required for downloading Mistral-7B, a gated model)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Groq API key — used for:
#   1. LLM chat completions (Fumii responses via llama-3.3-70b-versatile)
#   2. Whisper audio transcription (/api/transcribe endpoint)
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_key_here

# Mistral API key (optional — used for fine-tuning pipeline only)
MISTRAL_API_KEY=your_mistral_key_here
